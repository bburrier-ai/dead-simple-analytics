# Postgres (docker-compose)
POSTGRES_USER=dsa
POSTGRES_PASSWORD=dsa_dev_password
POSTGRES_DB=dead_simple_analytics
DATABASE_URL=postgresql+psycopg://dsa:dsa_dev_password@postgres:5432/dead_simple_analytics

# Host port (leave 8082 if a reverse proxy forwards to this app)
DSA_HOST_PORT=8082

# Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123456
JWT_SECRET=dev-change-me-in-production
JWT_EXPIRE_MINUTES=1440
SESSION_COOKIE_NAME=session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Collector
IP_HASH_SALT=dev-change-me-in-production
COLLECT_RATE_LIMIT_PER_MIN=120
PUBLIC_BASE_URL=http://localhost:8082

# Optional GeoIP (mount .mmdb into container)
GEOLITE2_DB_PATH=

# App
APP_ENV=local
CORS_ORIGINS=http://localhost:8082,http://localhost
LOG_LEVEL=INFO
